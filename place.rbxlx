						<string name="ScriptGuid">{de6b90a7-80cf-4839-b2d4-e50e2b99adc4}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">remotes</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">2ed5dce980b62c8909dc759400002228</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX77c346fb506b490db21a68231eeaca48">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local alloc = buffer_writer.alloc
local u8 = buffer_writer.u8
local u16 = buffer_writer.u16
local u32 = buffer_writer.u32
local i8 = buffer_writer.i8
local i16 = buffer_writer.i16
local i32 = buffer_writer.i32
local btrue = buffer_writer.btrue
local bfalse = buffer_writer.bfalse
local reference = buffer_writer.reference

export type serdes_data<T> = {read: (buff:buffer_writer.buffer_writer, cursor:number) -> (T,number), write: (buff:buffer_writer.buffer_writer, v:T) -> ()}

do
    local data: serdes_data<boolean> = {
        read = function(b, o)
            return (buffer.readu8(b.buff, o) == 1), 1
        end,
        write = function(b, v)
            alloc(b, 1)

            if v then
                btrue(b)
            else
                bfalse(b)
            end
        end,
    }

    function S_BOOL()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readu8(b.buff, o), 1
        end,
        write = function(b, v)
            alloc(b, 1)
            u8(b, v)
        end,
    }

    function S_U8()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readi8(b.buff, o), 1
        end,
        write = function(b, v)
            alloc(b, 1)
            i8(b, v)
        end,
    }

    function S_I8()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readu16(b.buff, o), 2
        end,
        write = function(b, v)
            alloc(b, 2)
            u16(b, v)
        end,
    }

    function S_U16()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readi16(b.buff, o), 2
        end,
        write = function(b, v)
            alloc(b, 2)
            i16(b, v)
        end,
    }

    function S_I16()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readu32(b.buff, o), 4
        end,
        write = function(b, v)
            alloc(b, 4)
            u32(b, v)
        end,
    }

    function S_U32()
        return data
    end
end
do
    local data: serdes_data<number> = {
        read = function(b, o)
            return buffer.readi32(b.buff, o), 4
        end,
        write = function(b, v)
            alloc(b, 4)
            i32(b, v)
        end,
    }

    function S_I32()
        return data
    end
end
do
    function S_TUPLE(...: serdes_data<any>)
        local packed = table.pack(...)
        local tuple_len = packed.n
        local data: serdes_data<{any}> = {
            read = function(b, cursor)
                local len = buffer.readu8(b.buff, cursor)
                local array = {}
                local arr_cursor = cursor + 1

                for i = 1, len do
                    local v, len = packed[i].read(b, arr_cursor)

                    array[i] = v

                    arr_cursor += len
                end

                return array, arr_cursor - cursor
            end,
            write = function(b, v)
                alloc(b, 1)
                u8(b, tuple_len)

                for i = 1, tuple_len do
                    packed[i].write(b, v[i])
                end
            end,
        }

        return data
    end
end
do
    function S_ARRAY<T>(t: serdes_data<T>)
        local read, write = t.read, t.write
        local data: serdes_data<{T}> = {
            read = function(b, cursor)
                local len = buffer.readu16(b.buff, cursor)
                local array = {}
                local arr_cursor = cursor + 2

                for i = 1, len do
                    local v, len = read(b, arr_cursor)

                    array[i] = v

                    arr_cursor += len
                end

                return array, arr_cursor - cursor
            end,
            write = function(b, v)
                local s = #v

                alloc(b, 2)
                u16(b, s)

                for i = 1, s do
                    write(b, v[i])
                end
            end,
        }

        return data
    end
end
do
    local map = {}

    function get_struct(template: {[string]: serdes_data<any>})
        if map[template] ~= nil then
            return map[template], #map[template]
        end

        local converted_struct = {}

        for i, v in template do
            converted_struct[#converted_struct + 1] = {
                index = i,
                val = v,
            }
        end

        table.sort(converted_struct, function(a0, a1): boolean
            return a0.index > a1.index
        end)

        local len = #converted_struct

        map[template] = converted_struct

        return converted_struct, len
    end
    function S_STRUCT(template: {[string]: serdes_data<any>})
        local ordered, len = get_struct(template)

        print(ordered, len, 'STRUCT')

        local data: serdes_data<{[string]: serdes_data<any>}> = {
            read = function(buff, cursor)
                local length = buffer.readu8(buff.buff, cursor)
                local str_cursor = cursor + 1
                local struct = {}

                for i = 1, length do
                    local r = ordered[i]
                    local value, offset = r.val.read(buff, str_cursor)

                    struct[r.index] = value

                    str_cursor += offset
                end

                return struct, str_cursor - cursor
            end,
            write = function(b, v)
                alloc(b, 1)
                u8(b, len)

                for i = 1, len do
                    local r = ordered[i]

                    r.val.write(b, v[r.index])
                end
            end,
        }

        return data
    end
end
do
    function S_OPTIONAL<T>(v: serdes_data<T>): serdes_data<T?>
        local read, write = v.read, v.write

        return {
            read = function(b, cursor)
                if buffer.readu8(b.buff, cursor) == 0 then
                    return nil, 1
                else
                    local item, length = read(b, cursor + 1)

                    return item, length + 1
                end
            end,
            write = function(b, value)
                local exists = value ~= nil

                alloc(b, 1)

                if exists then
                    btrue(b)
                else
                    bfalse(b)
                end
                if exists then
                    write(b, value::T)
                end
            end,
        }
    end
end
do
    local data: serdes_data<any> = {
        read = function(b, cursor)
            local v = buffer.readu8(b.buff, cursor)

            return b.references[v], 1
        end,
        write = function(b, v)
            alloc(b, 1)
            reference(b, v)
        end,
    }

    function S_REF()
        return data
    end
end

return table.freeze({
    REF = (S_REF()::never)::any,
    BOOL = (S_BOOL()::never)::boolean,
    U8 = (S_U8()::never)::number,
    I8 = (S_I8()::never)::number,
    U16 = (S_U16()::never)::number,
    I16 = (S_I16()::never)::number,
    U32 = (S_U32()::never)::number,
    I32 = (S_I32()::never)::number,
    TUPLE = (S_TUPLE::never)::<T...>(T...) -> T...,
    ARRAY = (S_ARRAY::never)::<T>(T) -> {T},
    STRUCT = (S_STRUCT::never)::<T>(T) -> T,
    OPTIONAL = (S_OPTIONAL::never)::<T>(T) -> T?,
    __TO_SERDES = function<T>(t: T): serdes_data<T>
        return t::never
    end,
    __PACK_TUPLE = function<T>(...: T): serdes_data<{any}>
        return ...::never
    end,
})
]]></ProtectedString>
						<string name="ScriptGuid">{4acb1044-57c4-40fd-b8a0-e300d9e0e856}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">serdes</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">2ed5dce980b62c8909dc759400002229</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX40f76464fd87462a82b63f86bf8a9134">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local RunService = game:GetService('RunService')
local read = require(script.Parent:WaitForChild('read'))
local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local alloc = buffer_writer.alloc
local u8 = buffer_writer.u8
local dump = require(script.Parent:WaitForChild('dump'))

@native
function create_super(): buffer_writer.buffer_writer
    return {
        size = 256,
        cursor = 0,
        buff = buffer.create(256),
        references = {},
    }
end

local players_reliable: {[Player]: buffer_writer.buffer_writer?} = {}
local players_unreliable: {[Player]: buffer_writer.buffer_writer?} = {}

@native
function send_reliable_packet(
    to: Player,
    id: number,
    writer: (buf:buffer_writer.buffer_writer, data:any) -> (),
    data: any
)
    local buf = players_reliable[to] or create_super()

    alloc(buf, 2)
    u8(buf, id)
    writer(buf, data)

    players_reliable[to] = buf
end
@native
function send_unreliable_packet(
    to: Player,
    id: number,
    writer: (buf:buffer_writer.buffer_writer, data:any) -> (),
    data: any
)
    local buf = players_unreliable[to] or create_super()

    alloc(buf, 2)
    u8(buf, id)
    writer(buf, data)

    players_unreliable[to] = buf
end
@native
function start()
    local reliable = Instance.new('RemoteEvent')

    reliable.Name = '.reliable'

    local unreliable = Instance.new('UnreliableRemoteEvent')

    unreliable.Name = '.unreliable'

    local remote_fn = Instance.new('RemoteFunction')

    remote_fn.Name = '.remote_fn'

    reliable.OnServerEvent:Connect(function(plr: Player, b, r)
        read(b, r, plr)
    end)
    unreliable.OnServerEvent:Connect(function(plr: Player, b, r)
        read(b, r, plr)
    end)

    reliable.Parent = ReplicatedStorage
    unreliable.Parent = ReplicatedStorage
    remote_fn.Parent = ReplicatedStorage

    RunService.Heartbeat:Connect(function()
        for _, plr in Players:GetPlayers()do
            do
                local buf = players_reliable[plr]

                if buf ~= nil and buf.cursor > 0 then
                    local dumpBuffer, references = dump(buf)

                    reliable:FireClient(plr, dumpBuffer, references)

                    buf.cursor = 0

                    table.clear(buf.references)
                end
            end
            do
                local buf = players_unreliable[plr]

                if buf ~= nil and buf.cursor > 0 then
                    local dumpBuffer, references = dump(buf)

                    unreliable:FireClient(plr, dumpBuffer, references)

                    buf.cursor = 0

                    table.clear(buf.references)
                end
            end
        end
    end)
end

return {
    start = start,
    send_reliable_packet = send_reliable_packet,
    send_unreliable_packet = send_unreliable_packet,
}
]]></ProtectedString>
						<string name="ScriptGuid">{881f6f61-cc55-45db-a80f-043ef8aa8843}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
