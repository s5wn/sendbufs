			<Item class="ModuleScript" referent="RBX89dacc4cca5d43c191533cb63ae001ce">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Players = game:GetService('Players')
local RunService = game:GetService('RunService')
local serdes = require(script:WaitForChild('serdes'))
local is_server = RunService:IsServer()
local server = require(script:WaitForChild('server-lifecycle'))
local client = require(script:WaitForChild('client-lifecycle'))
local remotes = require(script:WaitForChild('remotes'))
local metatables = require(script:WaitForChild('metatables'))
local constants = require(script:WaitForChild('constants'))

do
    local globalid = 0

    function take_next()
        globalid += 1

        return globalid
    end
    function add<T>(t: T): T
        remotes[globalid] = t::never

        return t
    end
end

function create_event<T>(t: T): metatables.t_event<T>
    return add(setmetatable({
        kind = 'event',
        listeners = {},
        schema = t,
        type = constants.EVENT_TYPE.RELIABLE,
        id = take_next(),
    }, if is_server then metatables.server_remote_metatable else metatables.client_remote_metatable))::never
end
function create_unreliable<T>(t: T): metatables.t_event<T>
    return add(setmetatable({
        kind = 'event',
        listeners = {},
        schema = t,
        type = constants.EVENT_TYPE.UNRELIABLE,
        id = take_next(),
    }, if is_server then metatables.server_remote_metatable else metatables.client_remote_metatable)::never)
end
function create_request<T, R>(input: T, output: R): metatables.t_fn<T, R>
    return add(setmetatable({
        callback = nil,
        kind = 'function',
        schema = input,
        schema_out = output,
        id = take_next(),
    }, if is_server then metatables.server_function_metatable else metatables.client_function_metatable)::never)
end

if is_server then
    server.start()
else
    client.start()
end

return table.freeze({
    create_event = create_event,
    create_unreliable = create_unreliable,
    create_request = create_request,
    schema = serdes,
})
]]></ProtectedString>
					<string name="ScriptGuid">{45c8b5ea-e65d-49ee-a92b-5cc713fb2848}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
					<string name="Name">sendbufs</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
					<UniqueId name="UniqueId">64b4e80451f61a6609dd15b600002b64</UniqueId>
				</Properties>
				<Item class="ModuleScript" referent="RBX81bdb377e52c4353b5f13411724432a8">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local RunService = game:GetService('RunService')
local read_iter = require(script.Parent:WaitForChild('read-iter'))
local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local alloc = buffer_writer.alloc
local u8 = buffer_writer.u8
local u16 = buffer_writer.u16
local dump = require(script.Parent:WaitForChild('dump'))
local read = require(script.Parent:WaitForChild('read'))

@native
function create_super(): buffer_writer.buffer_writer
    return {
        size = 256,
        cursor = 0,
        buff = buffer.create(256),
        references = {},
    }
end

local payload_reliable = create_super()
local payload_unreliable = create_super()

@native
function send_reliable_packet(id: number, writer: (buf:buffer_writer.buffer_writer, data:any) -> (), data: any)
    alloc(payload_reliable, 1)
    u8(payload_reliable, id)
    writer(payload_reliable, data)
end
@native
function send_unreliable_packet(id: number, writer: (buf:buffer_writer.buffer_writer, data:any) -> (), data: any)
    alloc(payload_unreliable, 1)
    u8(payload_unreliable, id)
    writer(payload_unreliable, data)
end
@native
function invoke_request(
    id: number,
    writer: (buf:buffer_writer.buffer_writer, data:any) -> (),
    reader: (buf:buffer_writer.buffer_writer, cursor:number) -> any,
    data: any
): (boolean,any)
    local buf = create_super()

    alloc(buf, 1)
    u8(buf, id)
    writer(buf, data)

    local remote_fn: RemoteFunction = ReplicatedStorage:WaitForChild('.remote_fn', math.huge)
    local success, nbuf, refs = remote_fn:InvokeServer(dump(buf))

    if (success) then
        local bc = buffer_writer.from(nbuf)

        bc.references = refs

        return true, reader(bc, 0)
    end

    return false
end
@native
function start()
    local reliable: RemoteEvent = ReplicatedStorage:WaitForChild('.reliable', math.huge)

    reliable.OnClientEvent:Connect(read)

    local unreliable: UnreliableRemoteEvent = ReplicatedStorage:WaitForChild('.unreliable', math.huge)

    unreliable.OnClientEvent:Connect(read)
    RunService.Heartbeat:Connect(function()
        if payload_reliable.cursor > 0 then
            local dump, refs = dump(payload_reliable)

            reliable:FireServer(dump, refs)

            payload_reliable.cursor = 0

            table.clear(payload_reliable.references)
        end
        if payload_unreliable.cursor > 0 then
            local b, r = dump(payload_unreliable)

            unreliable:FireServer(b, r)

            payload_unreliable.cursor = 0

            table.clear(payload_unreliable.references)
        end
    end)
end

return {
    start = start,
    send_reliable_packet = send_reliable_packet,
    send_unreliable_packet = send_unreliable_packet,
    invoke_request = invoke_request,
}
]]></ProtectedString>
						<string name="ScriptGuid">{564ee333-7891-43d2-9e8a-1ad8a295fbe8}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">client-lifecycle</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">64b4e80451f61a6609dd15b600002b65</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX901a8645801a4ed1abdf4b93a8197396">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local types = require(script.Parent:WaitForChild('types'))

return function(listeners: {types.fn_listener}, ...)
    local s = #listeners

    for i = 1, s do
        local r = listeners[i]

        if (r.once) then
            table.remove(listeners, i)
        end

        warn(r.fn, 'exists')
        task.defer(r.fn, ...)
    end
end
]]></ProtectedString>
						<string name="ScriptGuid">{0262e178-fdb7-406d-9278-acb6d820f1dc}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">fire-listeners</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">64b4e80451f61a6609dd15b600002b66</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBXdfdca4e64f9045bebadd10963f604f5f">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService('Players')
local RunService = game:GetService('RunService')
local client_lifecycle = require(script.Parent:WaitForChild('client-lifecycle'))
local server_lifecycle = require(script.Parent:WaitForChild('server-lifecycle'))
local types = require(script.Parent:WaitForChild('types'))
local serdes = require(script.Parent:WaitForChild('serdes'))
local constants = require(script.Parent:WaitForChild('constants'))
local client_remote_metatable = {}

client_remote_metatable.__index = client_remote_metatable

local server_remote_metatable = {}

server_remote_metatable.__index = server_remote_metatable

local server_function_metatable = {}

server_function_metatable.__index = server_function_metatable

local client_function_metatable = {}

client_function_metatable.__index = client_function_metatable

type event_comb_mt<T> = {__index: event_comb_mt<T>, connect: (self:t_event<T>, callback:(T, plr:Player?) -> (), once:boolean?) -> () -> (), wait: () -> T, fire_client: (self:t_event<T>, plr:Player | {Player}, arg:T) -> (), fire_all: (self:t_event<T>, arg:T) -> (), fire_server: (self:t_event<T>, arg:T) -> ()}
type fn_comb_mt<T, R> = {__index: fn_comb_mt<T, R>, invoke: (self:t_fn<T, R>, input:T) -> (boolean,R), set_callback: (self:t_fn<T, R>, cb:(T, plr:Player) -> R) -> ()}
export type t_event<T> = typeof(setmetatable({}::{kind: 'event', listeners: {types.fn_listener}, schema: serdes.serdes_data<T>, type: number, id: number}, ((RunService.IsServer() and server_remote_metatable or client_remote_metatable)::never)::event_comb_mt<T>))
export type t_fn<T, R> = typeof(setmetatable({}::{kind: 'function', callback: ((arg:T, plr:Player?) -> R)?, schema: serdes.serdes_data<T>, schema_out: serdes.serdes_data<{any}>, id: number}, ((RunService.IsServer() and server_function_metatable or client_function_metatable)::never)::fn_comb_mt<T, R>))

function connect_listener(listeners: {types.fn_listener}, fn: (...any) -> (), once: boolean?)
    local t = {
        fn = fn,
        once = once,
    }

    table.insert(listeners, t)

    return function()
        local i = table.find(listeners, t)

        if i ~= nil then
            table.remove(listeners, i)
        end
    end
end
function wait<T>(self: t_event<T>): T
    local coro = coroutine.running()

    connect_listener(self.listeners, function(...)
        task.defer(coro, ...)
    end, true)
    coroutine.yield()

    return nil::never
end
function connect<T>(self: t_event<T>, callback: (T) -> (), once: boolean?)
    return connect_listener(self.listeners, callback, once)
end
function to_player_table(t: Player | {Player}): {Player}
    if typeof(t) == 'table' then
        return t
    end

    return {t}
end
function client_remote_metatable.fire_server<T>(self: t_event<T>, arg: T)
    local write_fn = self.schema.write
    local fn = if self.type == constants.EVENT_TYPE.RELIABLE then client_lifecycle.send_reliable_packet else client_lifecycle.send_unreliable_packet;

    (fn::never)(self.id, write_fn, arg)
end

client_remote_metatable.wait = wait
client_remote_metatable.connect = connect

table.freeze(client_remote_metatable)

function client_function_metatable.invoke<T, R>(self: t_fn<T, R>, arg: T): (boolean,R)
    local write_fn = self.schema.write
    local read_fn = self.schema_out.read

    return client_lifecycle.invoke_request(self.id, write_fn, read_fn, arg)
end

table.freeze(client_function_metatable)

function server_remote_metatable.fire_client<T>(
    self: t_event<T>,
    plr: Player | {Player},
    arg: T
): ()
    local plr = to_player_table(plr)
    local write_fn = self.schema.write
    local fn = if self.type == constants.EVENT_TYPE.RELIABLE then server_lifecycle.send_reliable_packet else server_lifecycle.send_reliable_packet

    for i = 1, #plr do
        (fn::never)(plr[i], self.id, write_fn, arg)
    end
end
function server_remote_metatable.fire_all<T>(self: t_event<T>, arg: T): ()
    local plr = Players:GetPlayers()
    local write_fn = self.schema.write
    local fn = if self.type == constants.EVENT_TYPE.RELIABLE then server_lifecycle.send_reliable_packet else server_lifecycle.send_reliable_packet

    for i = 1, #plr do
        (fn::never)(plr[i], self.id, write_fn, arg)
    end
end

server_remote_metatable.wait = wait
server_remote_metatable.connect = connect

table.freeze(server_remote_metatable)

function server_function_metatable.set_callback<T, R>(
    self: t_fn<T, R>,
    cb: (arg:T, plr:Player?) -> R
)
    if (self.callback) then
        error('CALLBACK FN ALREADY EXISTS!')
    end

    print('callback set')

    self.callback = cb
end

table.freeze(server_function_metatable)

return table.freeze{
    client_remote_metatable = client_remote_metatable,
    client_function_metatable = client_function_metatable,
    server_remote_metatable = server_remote_metatable,
    server_function_metatable = server_function_metatable,
}
]]></ProtectedString>
						<string name="ScriptGuid">{3a943585-dd58-40c9-a434-ff0ee914c4e0}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">metatables</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">64b4e80451f61a6609dd15b600002b67</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBXc7f4be620bbc41849f278a51df8c1efc">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local fire_listeners = require(script.Parent:WaitForChild('fire-listeners'))
local remotes = require(script.Parent:WaitForChild('remotes'))
local from = buffer_writer.from

@native
function read_iter(reader_prop: string, b: buffer, refs: {unknown}?)
    local cursor = 0
    local totalLen = buffer.len(b)
    local sb = from(b)

    sb.references = refs or {}

    return function()
        if cursor >= totalLen then
            return
        end

        local rid = buffer.readu8(b, cursor)
        local remo = remotes[rid]

        cursor += 1

        local value, nc = remo[reader_prop].read(sb, cursor)

        cursor += nc

        return rid, value
    end
end

return (read_iter::never)::<T...>(reader_prop:string, b:buffer, refs:{unknown}?) -> () -> (number,any)
]]></ProtectedString>
						<string name="ScriptGuid">{c73fdbd3-2060-413e-b3ab-de971523a631}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">read-iter</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">64b4e80451f61a6609dd15b600002b68</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBXba43b61b3504446c90d1aaf6b6309542">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService('Players')
local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local fire_listeners = require(script.Parent:WaitForChild('fire-listeners'))
local remotes = require(script.Parent:WaitForChild('remotes'))
local from = buffer_writer.from

return @native
function(b: buffer, refs: {unknown}?, plr: Player?)
    local cursor = 0
    local totalLen = buffer.len(b)
    local sb = from(b)

    sb.references = refs or {}

    while cursor < totalLen do
        local remo = remotes[buffer.readu8(b, cursor)]

        cursor += 1

        local value, nc = remo.schema.read(sb, cursor)

        cursor += nc

        if remo.kind == 'event' and remo.listeners ~= nil then
            fire_listeners(remo.listeners, value, plr)
        end
    end
end
]]></ProtectedString>
