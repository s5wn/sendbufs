				<Item class="Script" referent="RBXbfd155bc40ca4bc795c965eb9fe8ecb1">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local RunService = game:GetService('RunService')
local network_objs = require(script.Parent:WaitForChild('network.objs'))

while RunService:IsRunning() do
    local s, res = network_objs.test:invoke({
        age = 4,
        pos = vector.create(25.111, -10000.315135, 3000000),
        pos2 = vector.create(25.1351, 10000, -3E6),
        pos3 = vector.create(-1.195315091, 10000.123859139898, 3000000.1395813897),
        cf = CFrame.lookAlong(Vector3.one, Vector3.new(1, 0, 1).Unit),
        name = 'my lil dota',
        random_numbers = {17, 38},
    })

    print('FN R', res)
end
]]></ProtectedString>
