				<Item class="Script" referent="RBX25b6b2f4c24a4fa0bdc57c4406a737ec">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local network_objs = require(script.Parent:WaitForChild('network.objs'))

warn('INIT SERVER', getmetatable(network_objs.test), network_objs.test)
network_objs.test:set_callback(function(arg, plr: Player?)
    warn'INIT CALLBACK'
    task.wait(3)
    print('rec', arg)

    return math.random(0, 1) == 1
end)
]]></ProtectedString>
