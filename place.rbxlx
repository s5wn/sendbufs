						<token name="RunContext">1</token>
						<string name="ScriptGuid">{76aa65c7-b106-455d-abf2-156b509ae9d1}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">network.test</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">2ed5dce980b62c8909dc759400002221</UniqueId>
					</Properties>
				</Item>
			</Item>
			<Item class="ModuleScript" referent="RBXb72f3ebdce2e42939bb7d7b0fca3e27d">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Players = game:GetService('Players')
local RunService = game:GetService('RunService')
local serdes = require(script:WaitForChild('serdes'))
local is_server = RunService:IsServer()
local server = require(script:WaitForChild('server-lifecycle'))
local client = require(script:WaitForChild('client-lifecycle'))
local remotes = require(script:WaitForChild('remotes'))
local types = require(script:WaitForChild('types'))

do
    local globalid = 0

    function take_next()
        globalid += 1

        return globalid
    end
    function add<T>(t: T): T
        remotes[globalid] = t::never

        return t
    end
end

local EVENT_TYPE = table.freeze({
    RELIABLE = 0,
    UNRELIABLE = 1,
})
local event_mt = {}

event_mt.__index = event_mt

local fn_mt = {}

fn_mt.__index = fn_mt

function to_player_table(t: Player | {Player}): {Player}
    if typeof(t) == 'table' then
        return t
    end

    return {t}
end

do
    function event_mt.fire_client(self: types.t_event<any>, plr: Player | {Player}, ...): ()
        local plr = to_player_table(plr)
        local write_fn = self.schema.write
        local fn = if self.type == EVENT_TYPE.RELIABLE then server.send_reliable_packet else server.send_reliable_packet

        for _, plr in plr do
            (fn::never)(plr, self.id, write_fn, ...)
        end
    end
    function event_mt.fire_server(self: types.t_event<any>, ...)
        local write_fn = self.schema.write
        local fn = if self.type == EVENT_TYPE.RELIABLE then client.send_reliable_packet else client.send_unreliable_packet;

        (fn::never)(self.id, write_fn, ...)
    end
    function event_mt.fire_all(self: types.t_event<any>, ...)
        local plrs = Players:GetPlayers()
        local write_fn = self.schema.write
        local fn = if self.type == EVENT_TYPE.RELIABLE then server.send_reliable_packet else server.send_unreliable_packet

        for _, plr in plrs do
            (fn::never)(plr, self.id, write_fn, ...)
        end
    end
    function connect_listener(listeners: {types.fn_listener}, fn: (...any) -> ())
        table.insert(listeners, fn)

        return function()
            local i = table.find(listeners, fn)

            if i ~= nil then
                table.remove(listeners, i)
            end
        end
    end
    function event_mt.connect_client(self: types.t_event<any>, cb: () -> ())
        return connect_listener(self.listeners, cb)
    end

    event_mt.connect_server = event_mt.connect_client

    table.freeze(event_mt)
end
do
    function fn_mt.set_callback<T>(self: types.t_fn<any>, cb: (plr:Player, ...any) -> ...any) end
    function fn_mt.invoke<T>(self: types.t_fn<any>, ...) end

    table.freeze(fn_mt)
end

function create_event<T>(t: T): types.t_event<T>
    return add(setmetatable({
        listeners = {},
        schema = t,
        type = EVENT_TYPE.RELIABLE,
        id = take_next(),
    }, event_mt)::never)
end
function create_unreliable<T>(t: T): types.t_event<T>
    return add(setmetatable({
        listeners = {},
        schema = t,
        type = EVENT_TYPE.UNRELIABLE,
        id = take_next(),
    }, event_mt)::never)
end
function create_query<T, R...>(input: T, ...: R...): types.t_fn<T, R...>
    return add(setmetatable({
        listeners = {},
        schema = input,
        schema_out = select(1, ...)::{any},
        id = take_next(),
    }, {})::never)
end

if is_server then
    server.start()
else
    client.start()
end

return table.freeze({
    create_event = create_event,
    create_unreliable = create_unreliable,
    create_query = create_query,
    schema = serdes,
})
]]></ProtectedString>
					<string name="ScriptGuid">{95f19777-50d6-4ad8-ac95-96100af65bb8}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
					<string name="Name">sendbufs</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
					<UniqueId name="UniqueId">2ed5dce980b62c8909dc759400002222</UniqueId>
				</Properties>
				<Item class="ModuleScript" referent="RBX84675b9604e4454c82e8cc5c7d2682ea">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[export type buffer_writer = {size: number, cursor: number, references: {unknown}, buff: buffer}

function create(): buffer_writer
    return {
        size = 12,
        references = {},
        buff = buffer.create(12),
        cursor = 0,
    }
end
function from(b: buffer)
    local len = buffer.len(b)
    local nb: buffer_writer = {
        buff = buffer.create(len),
        size = len,
        cursor = 0,
        references = {},
    }

    buffer.copy(nb.buff, 0, b)

    return nb
end
function alloc(buf: buffer_writer, bytes: number)
    if not (buf.cursor + bytes >= buf.size) then
        return
    end

    buf.size = math.floor(buf.size * 1.5)

    local newBuffer = buffer.create(buf.size)

    buffer.copy(newBuffer, 0, buf.buff)

    buf.buff = newBuffer
end
function dyn_alloc(buf: buffer_writer, bytes: number)
    while buf.cursor + bytes > buf.size do
        buf.size = math.floor(buf.size * 1.5)
    end

    local newBuffer = buffer.create(buf.size)

    buffer.copy(newBuffer, 0, buf.buff)

    buf.buff = newBuffer
end
function u8(buf: buffer_writer, value: number)
    buffer.writeu8(buf.buff, buf.cursor, value)

    buf.cursor += 1
end
function i8(buf: buffer_writer, value: number)
    buffer.writei8(buf.buff, buf.cursor, value)

    buf.cursor += 1
end
function reference(buf: buffer_writer, value: any)
    table.insert(buf.references, value)

    local index = #buf.references

    buffer.writeu8(buf.buff, buf.cursor, index)

    buf.cursor += 1
end
function u16(buf: buffer_writer, value: number)
    buffer.writeu16(buf.buff, buf.cursor, value)

    buf.cursor += 2
end
function i16(buf: buffer_writer, value: number)
    buffer.writeu16(buf.buff, buf.cursor, value)

    buf.cursor += 2
end
function u32(buf: buffer_writer, value: number)
    buffer.writeu32(buf.buff, buf.cursor, value)

    buf.cursor += 4
end
function writestring(buf: buffer_writer, value: string)
    buffer.writestring(buf.buff, buf.cursor, value)

    buf.cursor += string.len(value)
end
function i32(buf: buffer_writer, value: number)
    buffer.writei32(buf.buff, buf.cursor, value)

    buf.cursor += 4
end
function f32(buf: buffer_writer, value: number)
    buffer.writef32(buf.buff, buf.cursor, value)

    buf.cursor += 4
end
function f64(buf: buffer_writer, value: number)
    buffer.writef64(buf.buff, buf.cursor, value)

    buf.cursor += 8
end
function copy(buf: buffer_writer, value)
    buffer.copy(buf.buff, buf.cursor, value)

    buf.cursor += buffer.len(value)
end
function btrue(buf: buffer_writer)
    buffer.writeu8(buf.buff, buf.cursor, 1)

    buf.cursor += 1
end
function bfalse(buf: buffer_writer)
    buffer.writeu8(buf.buff, buf.cursor, 0)

    buf.cursor += 1
end

return table.freeze({
    create = create,
    alloc = alloc,
    u8 = u8,
    i8 = i8,
    u16 = u16,
    i16 = i16,
    u32 = u32,
    i32 = i32,
    f32 = f32,
    f64 = f64,
    copy = copy,
    btrue = btrue,
    bfalse = bfalse,
    reference = reference,
    writestring = writestring,
    dyn_alloc = dyn_alloc,
    from = from,
})
]]></ProtectedString>
						<string name="ScriptGuid">{1ca6ad5a-9fe7-4d65-8305-e37da44c11ed}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">buffer-writer</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">2ed5dce980b62c8909dc759400002223</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBXa21a22776a4f4cf3bfd2890287ff2cc7">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService('Players')
local ReplicatedStorage = game:GetService('ReplicatedStorage')
local RunService = game:GetService('RunService')
local buffer_writer = require(script.Parent:WaitForChild('buffer-writer'))
local alloc = buffer_writer.alloc
local u8 = buffer_writer.u8
local dump = require(script.Parent:WaitForChild('dump'))
local read = require(script.Parent:WaitForChild('read'))

@native
function create_super(): buffer_writer.buffer_writer
    return {
        size = 256,
        cursor = 0,
        buff = buffer.create(256),
        references = {},
    }
end

local payload_reliable = create_super()
local payload_unreliable = create_super()

@native
function send_reliable_packet(id: number, writer: (buf:buffer_writer.buffer_writer, data:any) -> (), data: any)
    alloc(payload_reliable, 2)
    u8(payload_reliable, id)
    writer(payload_reliable, data)
end
@native
function send_unreliable_packet(id: number, writer: (buf:buffer_writer.buffer_writer, data:any) -> (), data: any)
    alloc(payload_unreliable, 2)
    u8(payload_unreliable, id)
    writer(payload_unreliable, data)
end
@native
function start()
    local reliable: RemoteEvent = ReplicatedStorage:WaitForChild('.reliable', math.huge)

    reliable.OnClientEvent:Connect(read)

    local unreliable: UnreliableRemoteEvent = ReplicatedStorage:WaitForChild('.unreliable', math.huge)

    unreliable.OnClientEvent:Connect(read)

    local remote_fn: RemoteFunction = ReplicatedStorage:WaitForChild('.remote_fn', math.huge)

    RunService.Heartbeat:Connect(function()
        if payload_reliable.cursor > 0 then
            local dump, refs = dump(payload_reliable)

            reliable:FireServer(dump, refs)

            payload_reliable.cursor = 0

            table.clear(payload_reliable.references)
        end
        if payload_unreliable.cursor > 0 then
            local b, r = dump(payload_unreliable)

            unreliable:FireServer(b, r)

            payload_unreliable.cursor = 0

            table.clear(payload_unreliable.references)
        end
    end)
end

return {
    start = start,
    send_reliable_packet = send_reliable_packet,
    send_unreliable_packet = send_unreliable_packet,
}
]]></ProtectedString>
